{
  "name": "work-slate",
  "version": "1.1.0",
  "description": "Your daily console for planning, focus, and work clarity.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "node scripts/start-electron.js",
    "icons": "node scripts/generate-icons.js",
    "check": "node --check scripts/start-electron.js && node --check scripts/generate-icons.js && node --check scripts/release.js && node --check build/afterPack.js && node --check src/main.js && node --check src/preload.js && node --check src/floatingTimerPreload.js && node --check src/settingsStore.js && node --check src/trelloClient.js && node --check src/renderer/app.js && node --check src/renderer/floating-timer.js",
    "pack": "npm run icons && electron-builder --dir",
    "dist": "npm run icons && electron-builder --win nsis",
    "release": "node scripts/release.js"
  },
  "build": {
    "appId": "com.local.work-slate",
    "productName": "Work Slate",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/afterPack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "bwattleworth8",
        "repo": "work-slate",
        "releaseType": "release"
      }
    ],
    "artifactName": "Work-Slate-Setup-${version}.${ext}",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Work Slate"
    }
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
